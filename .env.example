# RPC endpoint used for the local mainnet fork (anvil dev environment).
# Any archive-capable mainnet RPC works (Alchemy, Infura, your own node).
MAINNET_RPC_URL=

# --- Event indexer (backend/indexer) ---
# RPC the indexer follows. Falls back to MAINNET_RPC_URL when unset.
INDEXER_RPC_URL=
# Deployed contract addresses the indexer watches.
MERIDIAN_POOL_ADDRESS=
MERIDIAN_CREDIT_MANAGER_ADDRESS=
MERIDIAN_LIQUIDATION_MODULE_ADDRESS=
# Block to start backfilling from (the deployment block).
INDEXER_START_BLOCK=0
# Tip polling interval in milliseconds.
INDEXER_POLL_INTERVAL_MS=4000
# Where the state snapshot is persisted between restarts.
INDEXER_SNAPSHOT_PATH=./indexer-state.json

# --- Backend API (backend/api) ---
# HTTP port the API listens on.
API_PORT=3001
# Path to the indexer snapshot the API reads (shared with the indexer above).
# INDEXER_SNAPSHOT_PATH is reused.
# Path to the on-chain risk parameters served at /risk-parameters.
API_RISK_PARAMS_PATH=../../contracts/config/risk-params.json
# Allowed CORS origin for browser clients (the web app). "*" is fine locally since the read
# endpoints are public; set a specific origin in a real deployment.
API_CORS_ORIGIN=*
# SIWE login: the domain and chain id clients must sign against.
API_SIWE_DOMAIN=localhost:3001
API_SIWE_CHAIN_ID=1
# Secret used to sign session tokens. Override in any real deployment.
API_SESSION_SECRET=dev-insecure-secret-change-me
# Session and login-nonce lifetimes in seconds.
API_SESSION_TTL_SECONDS=86400
API_NONCE_TTL_SECONDS=300
# WebSocket broadcast interval in milliseconds.
API_WS_BROADCAST_MS=5000

# --- Margin engine (backend/margin-engine) ---
# Host and port the FastAPI service binds to.
MARGIN_ENGINE_HOST=0.0.0.0
MARGIN_ENGINE_PORT=8000
# Override the risk parameters file (defaults to contracts/config/risk-params.json).
MERIDIAN_RISK_PARAMS_PATH=

# --- Liquidation keeper (backend/keeper) ---
# RPC the keeper submits through. Falls back to MAINNET_RPC_URL.
KEEPER_RPC_URL=
# Keeper signing key (hex, funded with gas). Never commit a real key.
KEEPER_PRIVATE_KEY=
# The keeper reuses MERIDIAN_LIQUIDATION_MODULE_ADDRESS (submit) and
# MERIDIAN_CREDIT_MANAGER_ADDRESS (health reads), and INDEXER_SNAPSHOT_PATH (candidates).
# Detection interval and retry policy.
KEEPER_INTERVAL_MS=4000
KEEPER_MAX_ATTEMPTS=3
KEEPER_BACKOFF_MS=1000
# Dry-run mode: detect and log only, never submit. Default true for safety.
KEEPER_DRY_RUN=true

# --- Alerts and monitoring (backend/alerts) ---
# HTTP port serving /health, /alerts, and /metrics. Reuses INDEXER_SNAPSHOT_PATH for state.
ALERTS_PORT=3002
# How often the liquidation baseline is advanced, in milliseconds.
ALERTS_POLL_MS=5000

# --- Web app (apps/web) ---
# Base URL the web app reads the backend API from. Defaults to the local dev API.
NEXT_PUBLIC_API_URL=http://localhost:3001
