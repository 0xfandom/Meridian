{
  "name": "meridian",
  "private": true,
  "version": "0.0.0",
  "description": "Non-custodial digital-asset prime brokerage",
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint && pnpm lint:sol",
    "lint:sol": "solhint 'contracts/src/**/*.sol'",
    "fmt": "prettier --write \"**/*.{js,ts,tsx,json,yaml,yml}\" && pnpm fmt:sol",
    "fmt:check": "prettier --check \"**/*.{js,ts,tsx,json,yaml,yml}\" && pnpm fmt:sol:check",
    "fmt:sol": "cd contracts && forge fmt",
    "fmt:sol:check": "cd contracts && forge fmt --check"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "solhint": "^5.0.5",
    "turbo": "^2.3.3"
  }
}
