{
  "name": "@meridian/alerts",
  "version": "0.0.0",
  "private": true,
  "description": "Alerting and metrics service for the Meridian off-chain stack",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
